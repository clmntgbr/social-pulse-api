## Aliases

alias mc='bin/console make:command'
alias me='bin/console make:entity'
alias mmr='bin/console make:entity --regenerate App'
alias mm='bin/console make:migration'
alias dmm='bin/console doctrine:migrations:migrate --no-interaction'
alias dsu='bin/console doctrine:schema:update -f'
alias ddc='bin/console doctrine:database:create'
alias ddd='bin/console doctrine:database:drop -f'
alias dfl='bin/console doctrine:fixture:load --no-interaction'
alias hfl='bin/console hautelook:fixtures:load -n'