meta {
  name: Get SocialAccounts
  type: http
  seq: 4
}

get {
  url: {{url_api}}api/social_accounts?socialAccountType=facebook_social_account
  body: none
  auth: bearer
}

params:query {
  socialAccountType: facebook_social_account
}

headers {
  accept: application/ld+json
}

auth:bearer {
  token: {{token}}
}
